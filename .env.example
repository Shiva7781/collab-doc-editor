# ─── Database ───────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/HOE

# ─── Authentication ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-key-here-change-this-in-production
NEXTAUTH_URL=http://localhost:3000

# ─── JWT (WebSocket auth) ────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# ─── WebSocket Server ────────────────────────────────────────────────────────
WS_PORT=3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ─── AI (Groq) ───────────────────────────────────────────────────────────────
# Get a free API key at: https://console.groq.com
GROQ_API_KEY=gsk_your-groq-api-key-here

# ─── App Config ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Security ─────────────────────────────────────────────────────────────────
# Max sync payload size in bytes (default: 5MB)
MAX_SYNC_PAYLOAD_BYTES=5242880

# ─── Footer / Branding ────────────────────────────────────────────────────────
NEXT_PUBLIC_AUTHOR_NAME=Shivanand Vishwakarma
NEXT_PUBLIC_GITHUB_URL=https://github.com/Shiva7781
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/shivanand-vishwakarma/
